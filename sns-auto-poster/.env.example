# ============================================================
# GCP設定
# ============================================================
GCP_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=asia-northeast1
VERTEX_MODEL=gemini-2.0-flash-001

# ============================================================
# HubSpot
# ============================================================
# HubSpot Private App Access Token
HUBSPOT_ACCESS_TOKEN=your-hubspot-access-token

# HubSpot に接続済みのSNSチャンネルGUID
# HubSpot → Marketing → Social → 各アカウントの設定から確認
HUBSPOT_CHANNEL_X=your-x-channel-guid
HUBSPOT_CHANNEL_INSTAGRAM=your-instagram-channel-guid
HUBSPOT_CHANNEL_FACEBOOK=your-facebook-channel-guid
HUBSPOT_CHANNEL_TIKTOK=your-tiktok-channel-guid
