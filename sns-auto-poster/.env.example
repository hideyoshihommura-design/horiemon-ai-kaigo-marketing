# Anthropic API キー（必須）
# https://console.anthropic.com でAPIキーを取得
ANTHROPIC_API_KEY=your_api_key_here

# 投稿のサブテーマ（毎日変えると投稿内容にバリエーションが出る）
# 例：介護記録のAI活用、シフト管理効率化、助成金活用、ChatGPT研修、人材育成、離職率改善
SNS_THEME=介護現場でのAI活用・業務効率化

# ビジネス・サービス名（投稿の主体）
BUSINESS_NAME=ホリエモンAI学校介護校

# 投稿する時刻（24時間表記 HH:MM）
SCHEDULE_TIME=09:00

# Web UIのポート番号
WEB_PORT=5000

# 投稿履歴の保存先ディレクトリ
OUTPUT_DIR=./output
